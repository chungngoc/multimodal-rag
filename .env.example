# Qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION_NAME=multimodal_rag

# Ollama
OLLAMA_HOST=http://localhost:11434
OLLAMA_TEXT_MODEL=mistral:7b-instruct
OLLAMA_VISION_MODEL=llava:7b

# Embedding model
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DEVICE=cpu

# App
APP_HOST=0.0.0.0
APP_PORT=7860
LOG_LEVEL=INFO

# AWS (filled at Step 11)
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=
ECR_REPOSITORY=multimodal-rag